<!--<?xml version="1.0" encoding="utf-8"?>-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Emergency Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_emergency_card"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" android:padding="18dp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="12dp" android:layout_height="12dp"
                    android:background="@color/accent_red" android:layout_marginEnd="10dp"/>
                <!-- Note: For pulse animation use ObjectAnimator in Kotlin -->
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="EMERGENCY CASE"
                    android:textColor="@color/accent_red" android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CRITICAL" android:textColor="@color/accent_red"
                    android:textSize="10sp" android:textStyle="bold"
                    android:background="@drawable/bg_badge_red" android:padding="5dp"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ramesh Sharma · 62y · Male"
                android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PID: MH-2024-00381 · Blood: O+"
                android:textColor="@color/text_muted" android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <!-- Vitals Grid -->
            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="3" android:layout_marginTop="14dp" android:useDefaultMargins="true">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical"
                    android:background="@drawable/bg_vital_chip" android:padding="10dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="88" android:textColor="#FF3B6B" android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="bpm" android:textColor="@color/text_muted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HEART RATE" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical"
                    android:background="@drawable/bg_vital_chip" android:padding="10dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="155/98" android:textColor="@color/accent_red"
                        android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="mmHg" android:textColor="@color/text_muted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BLOOD PRESSURE" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical"
                    android:background="@drawable/bg_vital_chip" android:padding="10dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="94%" android:textColor="@color/accent_green"
                        android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SpO₂" android:textColor="@color/text_muted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="OXYGEN" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <!-- AI Guidance Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🤖 AI First Aid Guidance (Ollama)"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Live" android:textColor="@color/accent_green"
                    android:textSize="10sp" android:background="@drawable/bg_badge_green" android:padding="5dp"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tvAiGuidance"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Based on patient history (Diabetes T2, Hypertension) and current vitals:\n\n1. 🔴 Do NOT give sugary drinks — patient is diabetic\n2. 💊 Check last Metformin dose — risk of hypoglycemia\n3. 🩺 Monitor BP every 5 min — currently elevated\n4. 🛏️ Keep patient calm, semi-reclined position\n5. 🚑 Prepare IV access — likely needs saline\n6. ⚠️ Avoid NSAIDs — kidney risk with diabetes"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>
                <Button android:id="@+id/btnRefreshAi"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_btn_primary"
                    android:text="🔄 Refresh AI Guidance"
                    android:textColor="#FFFFFF" android:textSize="14sp"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Symptoms Input -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋 Current Symptoms" android:textColor="@color/text_primary"
                android:textSize="13sp" android:textStyle="bold" android:padding="16dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <EditText android:id="@+id/etSymptoms"
                    android:layout_width="match_parent" android:layout_height="100dp"
                    android:background="@drawable/bg_input" android:padding="12dp"
                    android:hint="Describe current symptoms..." android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" android:gravity="top"
                    android:inputType="textMultiLine"/>
                <Button android:id="@+id/btnAnalyze"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_btn_emergency"
                    android:text="Analyze with AI →" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:layout_marginTop="10dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>