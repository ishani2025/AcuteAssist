<!--<?xml version="1.0" encoding="utf-8"?>-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="20dp"
            android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Patient Record" android:textColor="@color/text_primary"
                    android:textSize="20sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dr. Sharma · AIIMS New Delhi" android:textColor="@color/text_muted"
                    android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● Active" android:textColor="@color/accent_green"
                android:textSize="10sp" android:textStyle="bold"
                android:background="@drawable/bg_badge_green" android:padding="6dp"/>
        </LinearLayout>

        <!-- Patient Hero Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_patient_hero"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="16dp"
            android:padding="18dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="52dp" android:layout_height="52dp"
                    android:text="RS" android:textColor="#FFFFFF" android:textSize="18sp"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/bg_avatar" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ramesh Sharma" android:textColor="@color/text_primary"
                        android:textSize="17sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PID: MH-2024-00381 · Admitted 12 Feb 2025"
                        android:textColor="@color/text_muted" android:textSize="11sp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="5dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="● Diabetic" android:textColor="@color/accent_red"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@drawable/bg_badge_red" android:padding="4dp"
                            android:layout_marginEnd="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hypertensive" android:textColor="@color/yellow"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@drawable/bg_badge_yellow" android:padding="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Vitals Row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_vital_chip" android:padding="8dp"
                    android:layout_marginEnd="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="O+" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BLOOD" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_vital_chip" android:padding="8dp"
                    android:layout_marginHorizontal="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="62y" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AGE" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_vital_chip" android:padding="8dp"
                    android:layout_marginHorizontal="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="72kg" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WEIGHT" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_vital_chip" android:padding="8dp"
                    android:layout_marginStart="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="173cm" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HEIGHT" android:textColor="@color/text_muted" android:textSize="9sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Basic Info Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🪪 Basic Information"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Edit" android:textColor="@color/accent"
                    android:textSize="12sp" android:textStyle="bold"
                    android:background="@drawable/bg_badge_blue" android:padding="6dp"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <!-- Info rows -->
                <include layout="@layout/item_info_row"
                    android:id="@+id/rowName"/>
                <!-- You'll populate these in Kotlin -->
            </LinearLayout>
        </LinearLayout>

        <!-- Conditions Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🔴 Active Medical Conditions"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+ Add" android:textColor="@color/accent"
                    android:textSize="12sp" android:background="@drawable/bg_badge_blue" android:padding="6dp"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>
            <LinearLayout android:id="@+id/conditionsContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <!-- Conditions populated programmatically -->
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>